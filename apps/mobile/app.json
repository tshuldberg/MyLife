{
  "expo": {
    "name": "MyLife",
    "slug": "mylife",
    "scheme": "mylife",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.mylife.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.mylife.app",
      "adaptiveIcon": {
        "backgroundColor": "#0E0C09"
      }
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-sharing",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 26
          }
        }
      ],
      [
        "react-native-health",
        {
          "healthSharePermission": "Allow MyLife Fast to read your health data for weight sync.",
          "healthUpdatePermission": "Allow MyLife Fast to write fasting sessions to Apple Health."
        }
      ],
      "expo-health-connect"
    ]
  }
}
